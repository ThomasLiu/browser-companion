{
  "manifest_version": 3,
  "name": "Browser Companion",
  "version": "0.1.0",
  "description": "Enable AI Agents to control Chrome browser via WebSocket/JSON-RPC",
  "permissions": [
    "activeTab",
    "debugger",
    "tabs",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["hermes-bridge.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
